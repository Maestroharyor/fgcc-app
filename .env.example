# SkillUp 1.0 — env template
# Copy this file to `.env.local` and fill in real values for your environment.
# `.env.local` is gitignored; `.env.example` is the version checked into git.
#
# The runtime is forgiving: missing keys produce empty-result fallbacks rather
# than crashes, so the dev server boots even without these set. Production
# absolutely needs Supabase + Resend + CRON_SECRET set; everything else is
# optional but strongly recommended.

# ────────────────────────────────────────────────────────────────────────────
# Supabase — get these from https://app.supabase.com → Project → Settings →
# API Keys. Use the modern keys (sb_publishable_… / sb_secret_…) — the legacy
# JWT-based anon/service_role keys are deprecated and removed end-of-2026.
# Publishable key is safe to expose; secret key bypasses RLS and is server-only.
# ────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# ────────────────────────────────────────────────────────────────────────────
# Resend (transactional email) — https://resend.com/api-keys
# Real keys start with `re_`.
# ADMIN_NOTIFICATION_EMAILS is a comma-separated list (empty = no admin alerts).
# ────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM="SkillUp 1.0 <noreply@skillup.fgccement.org>"
ADMIN_NOTIFICATION_EMAILS=admin@example.com

# ────────────────────────────────────────────────────────────────────────────
# Termii SMS (Nigerian carrier route) — https://accounts.termii.com
# TERMII_SENDER_ID must be a pre-approved alphanumeric ID in your Termii
# dashboard (default "SKILLUP" if you go through the approval flow).
# ────────────────────────────────────────────────────────────────────────────
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=SKILLUP

# ────────────────────────────────────────────────────────────────────────────
# Cron — Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}` when the
# env var is set in production. Use a long random string in real environments.
# Generate one with: openssl rand -hex 32
# ────────────────────────────────────────────────────────────────────────────
CRON_SECRET=replace-with-openssl-rand-hex-32

# ────────────────────────────────────────────────────────────────────────────
# Public site config
# NEXT_PUBLIC_SITE_URL is the absolute origin used in transactional emails
# (CTA links, QR pages, etc.). Set it to your production domain in prod.
# NEXT_PUBLIC_EVENT_START_ISO is the countdown target on the landing page.
# ────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_EVENT_START_ISO=2026-06-12T09:00:00+01:00
